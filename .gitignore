# flutes — .gitignore
# Stash-recovered 2026-05-23.

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*~

# SolidWorks lock + backup files
*.~*
~$*
*.bak
*.SLDBAK

# Sentinel test files (write-permission probes)
.test-write
**/.test-write

# Photo working files
*.psd
*.lrcat
*.lrcat-journal
*.xmp

# Raw camera files
*.cr2
*.CR2
*.nef
*.NEF
*.dng
*.DNG

# Video
*.mov
*.MOV
*.mp4
*.MP4

# Stash-recovery sidecars
stash-recovered-*/

# Pack-and-Go archives
*.7z

# Local-only folder convention
/raw/
